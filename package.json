{
  "name": "konglo-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy --yes",
    "test": "vitest run && vitest run -c vitest.convex.config.ts",
    "test:node": "vitest run",
    "test:convex": "vitest run -c vitest.convex.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "deploy:verify": "bash scripts/deploy-verify.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.50",
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.80",
    "@convex-dev/rate-limiter": "^0.3.2",
    "ai": "^4.3.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.27.0",
    "geoip-lite": "^2.0.3",
    "lucide-react": "^0.469.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "convex-test": "^0.0.38",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
