# Convex (Cloud or self-hosted). Set by `npx convex dev` locally, and by your
# host's build args / env for production. These are baked into the client bundle.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# @convex-dev/auth — generated by `npx @convex-dev/auth` (JWT keypair + JWKS).
# Stored as Convex env vars, NOT here in prod. Listed for reference:
# JWT_PRIVATE_KEY=
# JWKS=
# SITE_URL=

# Demo quick-login (TEMPORARY). When DEMO_MODE=1, the /login + / surfaces render
# "masuk cepat" buttons for konglo@ / ajudan@ using DEMO_PASSWORD. Runtime env
# (NOT NEXT_PUBLIC) — forwarded to the client ONLY while enabled. SECURITY: this
# publishes the demo password to anyone who opens the public login page. Use a
# throwaway/rotatable password and turn DEMO_MODE off to disable instantly.
# DEMO_MODE=1
# DEMO_PASSWORD=
